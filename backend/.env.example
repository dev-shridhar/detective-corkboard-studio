# Application
APP_NAME="Detective Corkboard Studio"
ENVIRONMENT=development

# Database — replace with your Neon/PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/corkboard_db

# JWT — generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","https://corkboard.learnwitharies.com"]
